{
  "name": "agenv-cli",
  "version": "2.1.0",
  "description": "Generate portable AI workspace configs for any web development project — one manifest for Copilot, Claude, Codex, and MCP.",
  "keywords": [
    "ai",
    "cli",
    "developer-tools",
    "web-development",
    "mcp",
    "codex",
    "copilot",
    "claude",
    "cursor",
    "windsurf",
    "workspace",
    "web-app",
    "api-service",
    "frontend",
    "internal-tools",
    "agents-md",
    "claude-code",
    "ai-rules",
    "ai-config"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samuelyoo/agenv.git"
  },
  "homepage": "https://samuelyoo.github.io/agenv/",
  "bugs": {
    "url": "https://github.com/samuelyoo/agenv/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "agenv": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^13.1.0",
    "yaml": "^2.8.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
