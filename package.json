{
  "name": "agenv",
  "version": "0.1.0",
  "description": "Bootstrap a portable, reviewable AI workspace for dashboard repositories.",
  "keywords": [
    "ai",
    "cli",
    "developer-tools",
    "mcp",
    "codex",
    "copilot",
    "claude",
    "workspace",
    "dashboard"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "agenv": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
